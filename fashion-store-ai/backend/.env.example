APP_NAME=Fashion Store AI
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=fashion_store
